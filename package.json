{
  "name": "veinzflow",
  "version": "1.0.0",
  "private": true,
  "description": "Research operations system for the VeinzFlow team",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:notion": "tsx scripts/setup-notion.ts",
    "telegram:webhook:set": "tsx scripts/telegram-admin.ts webhook:set",
    "telegram:webhook:status": "tsx scripts/telegram-admin.ts webhook:status",
    "telegram:webhook:delete": "tsx scripts/telegram-admin.ts webhook:delete",
    "telegram:webhook:reset": "tsx scripts/telegram-admin.ts webhook:reset",
    "telegram:webhook:flush": "tsx scripts/telegram-admin.ts webhook:flush",
    "telegram:test": "tsx scripts/telegram-admin.ts test",
    "telegram:doctor": "tsx scripts/telegram-admin.ts doctor",
    "telegram:register": "npm run telegram:webhook:set",
    "telegram:delete-webhook": "npm run telegram:webhook:delete",
    "env:verify": "tsx scripts/verify-environment.ts",
    "seed:demo": "tsx scripts/seed-demo-data.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@google/genai": "^2.13.0",
    "@next/env": "^16.2.11",
    "@notionhq/client": "latest",
    "googleapis": "latest",
    "next": "latest",
    "openai": "latest",
    "react": "latest",
    "react-dom": "latest",
    "resend": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
